# Supabase — copy to .env.local and fill in values
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only — never prefix with VITE_ (must not be exposed to browser)
# Get from: Supabase dashboard → Project Settings → API → Secret key
# Used by scripts/seed-books.mjs and Vercel serverless functions
# SUPABASE_SERVICE_KEY=your-service-role-key-here

# AI Insights — server-only, used by api/generate-insights.ts
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
